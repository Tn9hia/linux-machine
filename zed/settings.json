// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "ssh_connections": [
    {
      "host": "client",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/ubuntu/ansible"
          ]
        }
      ]
    }
  ],
  "diff_view_style": "unified",
  "cli_default_open_behavior": "new_window",
  "proxy": "",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "tree_view": false,
    "sort_by_path": true,
    "dock": "left",
  },
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "model": "default",
      },
      "type": "registry",
    },
    "your_agent": {
      "type": "custom",
      "command": "path_to_executable",
    },
  },
  "languages": {
    "YAML": {
      "show_edit_predictions": true,
    },
  },
  "tab_size": 2,
  "indent_guides": {
    "background_coloring": "disabled",
  },
  "tabs": {
    "git_status": false,
    "file_icons": true,
  },
  "restore_on_startup": "last_workspace",
  "completions": {
    "words": "fallback",
  },
  "inlay_hints": {
    "enabled": true,
    "show_background": false,
  },
  "preview_tabs": {
    "enable_preview_from_file_finder": false,
  },
  "title_bar": {
    "show_menus": false,
  },
  "project_panel": {
    "git_status_indicator": true,
    "bold_folder_labels": true,
    "dock": "left",
    "button": true,
  },
  "terminal": {
    "option_as_meta": true,
    "shell": "system",
    "cursor_shape": "block",
    "copy_on_select": true,
    "blinking": "on",
    "toolbar": {
      "breadcrumbs": false,
    },
    "font_family": ".ZedMono",
    "default_width": 640,
    "default_height": 320,
    "line_height": "comfortable",
  },
  "edit_predictions": {
    "provider": "mercury",
    "mode": "eager",
  },
  "hard_tabs": false,
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "soft_wrap": "editor_width",
  "toolbar": {
    "code_actions": true,
  },
  "ui_font_weight": 400.0,
  "disable_ai": false,
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "play_sound_when_agent_done": "always",
    "profiles": {
      "agent": {
        "default_model": {
          "provider": "google",
          "model": "gemini-3-pro-preview",
        },
        "name": "agent",
        "tools": {
          "delete_path": true,
          "create_directory": true,
          "read_file": true,
          "open": true,
          "now": true,
          "move_path": true,
          "list_directory": true,
          "grep": true,
          "find_path": true,
          "fetch": true,
          "edit_file": true,
          "diagnostics": true,
          "copy_path": true,
          "terminal": true,
          "thinking": true,
        },
        "enable_all_context_servers": false,
        "context_servers": {},
      },
    },
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "anthropic",
      "model": "claude-opus-4-6-latest",
    },
    "inline_assistant_model": {
      "provider": "ollama",
      "model": "codegemma:2b",
    },
    "model_parameters": [],
  },
  "vim_mode": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "file_types": {
    "terraform": ["*.tf"],
  },
  "icon_theme": "Catppuccin Mocha",
  "ui_font_size": 15.0,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "dark",
    "light": "One Dark",
    "dark": "Ayu Dark",
  },
}
